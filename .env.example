# ════════════════════════════════════════════════════════════════════
#  DataFlow Studio — Environment Variables
#  Copy this file to `.env` and fill in your values.
#  NEVER commit `.env` to version control.
# ════════════════════════════════════════════════════════════════════

# ── Application ───────────────────────────────────────────────────
ENVIRONMENT=development        # development | production
DEBUG=true                     # true in dev, false in prod
PORT=5000
SECRET_KEY=change-this-to-a-random-secret-in-production

# ── CORS ──────────────────────────────────────────────────────────
# Comma-separated list of allowed origins. Use * in development only.
CORS_ORIGINS=http://localhost:3001,http://localhost:5000

# ── Database ──────────────────────────────────────────────────────
# Default is SQLite (file-based). For PostgreSQL in production:
# DATABASE_URL=postgresql://user:password@host:5432/dbname
DATABASE_URL=sqlite:///dataflow.db

# ── Data file path ────────────────────────────────────────────────
DATA_FILE=data/sample_sales.csv

# ── Logging ───────────────────────────────────────────────────────
LOG_LEVEL=INFO                 # DEBUG | INFO | WARNING | ERROR
LOG_FORMAT=text                # text | json
# LOG_FILE=logs/app.log        # Optional: write logs to a file

# ── ETL configuration ─────────────────────────────────────────────
ETL_BATCH_SIZE=1000
ETL_MAX_RETRIES=3
ETL_RETRY_DELAY=0.5            # seconds (base, doubles each retry)
ETL_QUALITY_THRESHOLD=0.80     # min acceptable quality score (0–1)
