# ════════════════════════════════════════════════════════════════════
#  DataFlow Studio — .gitignore
# ════════════════════════════════════════════════════════════════════

# ── Python ────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
.eggs/
dist/
build/
.Python

# ── Virtual environments ──────────────────────────────────────────
venv/
env/
ENV/
.venv/

# ── Environment variables (NEVER commit secrets) ──────────────────
.env
.env.local
.env.*.local

# ── Database & runtime artefacts ─────────────────────────────────
*.db
*.sqlite
*.sqlite3
/tmp/

# ── Logs ─────────────────────────────────────────────────────────
logs/
*.log

# ── Node / React ─────────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── React build output ────────────────────────────────────────────
frontend/build/
frontend/.env.local
frontend/.env.development.local
frontend/.env.test.local
frontend/.env.production.local

# ── IDEs & editors ───────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~

# ── OS ────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── Legacy root-level files (safe to delete manually) ────────────
app.py
app_modern.py
config.py
extract.py
transform.py
load_data.py
demo_data.py
MODERNIZATION_GUIDE.md
MODERNIZATION_SUMMARY.md
QUICK_START_MODERN.md
PREVIEW.html
