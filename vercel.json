{
  "version": 2,
  "name": "dataflow-studio",
  "buildCommand": "cd frontend && npm install && npm run build",
  "outputDirectory": "frontend/build",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index.py" },
    { "source": "/(.*)",     "destination": "/index.html"   }
  ],
  "env": {
    "ENVIRONMENT": "production",
    "VERCEL": "1"
  }
}
